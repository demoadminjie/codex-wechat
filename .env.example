# Weixin account selection
# Leave empty when there is only one logged-in account.
CODEX_WECHAT_ACCOUNT_ID=
CODEX_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com

# Restrict which Weixin user IDs can control this bot.
# Comma-separated. Leave empty to allow any user who can message the bot.
CODEX_WECHAT_ALLOWED_USER_IDS=

# Optional default workspace. If set, the bot can be used without `/codex bind`.
CODEX_WECHAT_DEFAULT_WORKSPACE=

# Restrict which local directories can be bound from Weixin.
# Comma-separated absolute paths. Leave empty to allow any absolute path.
CODEX_WECHAT_WORKSPACE_ALLOWLIST=

# Optional Codex defaults.
CODEX_WECHAT_DEFAULT_CODEX_MODEL=
CODEX_WECHAT_DEFAULT_CODEX_EFFORT=
CODEX_WECHAT_DEFAULT_CODEX_ACCESS_MODE=default

# Optional explicit Codex endpoint. Leave empty to spawn `codex app-server`.
CODEX_WECHAT_CODEX_ENDPOINT=
CODEX_WECHAT_CODEX_COMMAND=

# Runtime behavior
CODEX_WECHAT_ENABLE_TYPING=true
CODEX_WECHAT_DEFAULT_WORKSPACE_ID=default

# Optional state paths
CODEX_WECHAT_STATE_DIR=/Users/your-name/.codex-wechat
CODEX_WECHAT_SESSIONS_FILE=/Users/your-name/.codex-wechat/sessions.json
CODEX_WECHAT_SYNC_BUFFER_DIR=/Users/your-name/.codex-wechat/sync-buf
